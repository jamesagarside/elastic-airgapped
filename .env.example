# ── Stack ────────────────────────────────────────────────────────────────────
ELASTIC_VERSION=9.3.4
CLUSTER_NAME=elastic-lab
ELASTIC_NS=elastic
ECK_NAMESPACE=elastic-system

# ── ECK License ──────────────────────────────────────────────────────────────
# Tier options:
#   trial      — 30-day Enterprise trial (default; can only be started once per cluster)
#   basic      — free tier; any existing trial/enterprise license secret is removed
#   enterprise — requires a JSON license file from Elastic (set ECK_LICENSE_FILE)
ECK_LICENSE_TIER=trial
# Absolute or repo-relative path to the Enterprise license JSON file.
# Only used when ECK_LICENSE_TIER=enterprise.
ECK_LICENSE_FILE=

# ── Ingress hostnames ─────────────────────────────────────────────────────────
# .localhost is RFC 6761 reserved for loopback use.
# Chrome and Firefox resolve *.localhost → 127.0.0.1 natively (no hosts file needed).
# Safari requires  make add-hosts  to add /etc/hosts entries.
KIBANA_HOSTNAME=kibana.localhost
ES_HOSTNAME=elasticsearch.localhost

# ── Elastic Package Registry (EPR) ───────────────────────────────────────────
# Runs inside the cluster so Fleet integrations work air-gapped.
# Tags: lite (smaller), production (full catalogue).
EPR_IMAGE=docker.elastic.co/package-registry/distribution:lite

# ── Resource envelope ────────────────────────────────────────────────────────
# Tune these for your laptop. CI overrides them in .github/workflows/test-e2e.yml.
# Memory accepts any Kubernetes quantity (512Mi, 1Gi, 2Gi, ...).
ES_DEFAULT_COUNT=2
ES_ML_COUNT=1
ES_DEFAULT_MEM=2Gi
ES_ML_MEM=4Gi
KIBANA_MEM=2Gi
FLEET_MEM=1Gi
AGENT_MEM=1Gi
LOGSTASH_MEM=2Gi
MAPS_MEM=1Gi
EPR_MEM=512Mi

# ── LM Studio ────────────────────────────────────────────────────────────────
# Base URL and port are combined by the Makefile into LLM_CONNECTOR_URL:
#   $(LLM_CONNECTOR_BASE_URL):$(LM_STUDIO_PORT)/v1
# host.docker.internal reaches the Mac host from inside a Kubernetes pod.
LLM_CONNECTOR_BASE_URL=http://host.docker.internal
LM_STUDIO_PORT=1234

# ── LLM Connector — LM Studio (local, OpenAI-compatible) ─────────────────────
# No real API key is required by LM Studio; any non-empty string works.
LLM_CONNECTOR_NAME=Qwen3.5-9B (LM Studio)
LLM_CONNECTOR_TYPE=OpenAI
LLM_CONNECTOR_MODEL=qwen/qwen3.5-9b
LLM_CONNECTOR_API_KEY=lm-studio
